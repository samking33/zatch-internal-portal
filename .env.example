NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?appName=<app-name>
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=replace-me
CORS_ORIGIN=http://localhost:3000
SENTRY_DSN=
MOBILE_API_KEY=replace-me
CLOUDINARY_CLOUD_NAME=demo
ZATCH_UPSTREAM_API_URL=https://<upstream-host>
ZATCH_UPSTREAM_API_TOKEN=<upstream-admin-jwt>
ZATCH_UPSTREAM_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
ZATCH_UPSTREAM_MONGODB_DB_NAME=zatch
ZATCH_UPSTREAM_SELLER_DETAIL_PATH=/api/v1/user/profile/:userId
ZATCH_UPSTREAM_SELLER_APPROVAL_PATH=/api/v1/user/seller/approve
